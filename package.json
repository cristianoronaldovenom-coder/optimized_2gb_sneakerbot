{
  "name": "sneakerbot",
  "version": "1.0.0",
  "description": "SneakerBot - Automated sneaker checkout bot API",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "start": "NODE_OPTIONS=\"--max-old-space-size=768\" NODE_ENV=production node app.js",
    "dev": "node --watch app.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "migrate": "knex migrate:latest",
    "seed": "knex seed:run"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "express": "^4.18.2",
    "express-validation": "^4.1.0",
    "got-scraping": "^4.2.1",
    "joi": "^17.11.0",
    "knex": "^3.1.0",
    "nodemailer": "^6.9.7",
    "puppeteer-core": "^24.42.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "winston": "^3.11.0",
    "better-sqlite3": "^11.7.0",
    "lru-cache": "^11.1.0",
    "p-queue": "^8.0.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "knex-mock-client": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  }
}